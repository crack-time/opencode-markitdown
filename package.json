{
  "name": "opencode-markitdown",
  "version": "1.0.4",
  "description": "OpenCode plugin for document-to-Markdown conversion via Microsoft MarkItDown",
  "type": "module",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "esbuild opencode-markitdown.ts --bundle --platform=node --format=esm --external:@opencode-ai/plugin --outfile=dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "markitdown",
    "plugin",
    "document",
    "markdown",
    "pdf",
    "conversion"
  ],
  "author": "Chen",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crack-time/opencode-markitdown.git"
  },
  "bugs": {
    "url": "https://github.com/crack-time/opencode-markitdown/issues"
  },
  "homepage": "https://github.com/crack-time/opencode-markitdown#readme"
}
